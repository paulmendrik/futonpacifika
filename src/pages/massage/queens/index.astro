---
import { Picture } from "astro:assets";
import { urlFor } from "@/sanity/image";
import { sanityClient } from "sanity:client";
import Main from "@/layouts/Main.astro";
const queens = await sanityClient.fetch(`*[_type == "queens"]`);
---

<Main title="Queen Size Futon Mats" header="Queen Size Futon Mats">
<div class="w-full">
<div class="grid grid-cols-1 lg:grid-cols-3 md:grid-cols-3 lg:gap-8 md:gap-4 gap-6 relative">
{queens.map((queen:any) => (
<a href={`/massage/queens/${queen.slug?.current}`} >
<figure>
<Picture class="max-w-full overflow-hidden" src={urlFor(queen.futon).format('webp').sharpen(80).url()} inferSize alt={queen.title} />
<figcaption class="py-4" >
<div class=" text-base uppercase text-red-600 text-center">
{queen.title}
</div>
<div class="text-sm text-red-700">
{queen.description}
</div>
</figcaption>
</figure>
</a>
))}
</div>
</div>
</Main>