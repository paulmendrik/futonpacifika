---
import Base from "@/layouts/Base.astro";
---

<Base title="Order Confirmation" header="Order Confirmation">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <div id="order-confirmation-container">
      <div class="text-center py-8">
        <p class="text-gray-600">Loading your order details...</p>
      </div>
    </div>
  </div>
</Base>

<script is:inline>
  // Get order data from localStorage
  const lastOrderJson = localStorage.getItem("snipcartLastOrder");

  if (!lastOrderJson) {
    // No order data found
    document.getElementById("order-confirmation-container").innerHTML = `
      <div class="bg-white rounded-lg shadow-lg p-8 text-center">
        <h1 class="text-2xl font-bold text-gray-900 mb-4">Thank you for your order!</h1>
        <p class="text-gray-600">Your order was processed successfully.</p>
        <a href="/" class="inline-block mt-6 bg-blue-600 text-white px-6 py-3 rounded font-medium hover:bg-blue-700 transition">
          Continue Shopping
        </a>
      </div>
    `;
  } else {
    const order = JSON.parse(lastOrderJson);

    console.log("Order object:", order); // Debug log to see what we have

    // Check if this is a deferred payment
    // paymentDetails.method === "DeferredPayment" indicates deferred payment
    const isDeferred =
      order.paymentDetails && order.paymentDetails.method === "DeferredPayment";

    // Build items list HTML - items are nested in order.items.items
    let itemsHTML = "";
    const itemsArray =
      order.items && order.items.items ? order.items.items : [];

    if (itemsArray.length > 0) {
      itemsHTML = itemsArray
        .map(
          (item) => `
        <div class="flex justify-between py-3 border-b border-gray-200">
          <div>
            <p class="font-medium text-gray-900">${item.name || "Item"}</p>
            <p class="text-sm text-gray-600">Quantity: ${item.quantity || 1} × £${(item.price || 0).toFixed(2)}</p>
          </div>
          <p class="font-medium text-gray-900">£${((item.price || 0) * (item.quantity || 1)).toFixed(2)}</p>
        </div>
      `
        )
        .join("");
    } else {
      // No items found - just show a message
      itemsHTML =
        '<p class="text-gray-600">Order items will be listed in your confirmation email.</p>';
    }

    // Build payment instructions HTML (only for deferred payments)
    let paymentInstructionsHTML = "";

    if (isDeferred) {
      paymentInstructionsHTML = `
        <div class="border-t border-gray-200 pt-6 mt-6">
          <div class="bg-yellow-50 border border-yellow-200 rounded p-4 mb-6">
            <p class="text-sm text-yellow-800 font-medium">
              ⚠️ Your order is awaiting payment. Please complete payment within 7 business days.
            </p>
          </div>

          <h2 class="text-xl font-bold text-gray-900 mb-4">Payment Instructions</h2>
          <p class="text-gray-600 mb-6">Please use one of these methods to complete your payment:</p>
          
          <div class="space-y-6">
            <div class="bg-blue-50 border-l-4 border-blue-600 p-6 rounded">
              <h3 class="text-lg font-semibold text-blue-900 mb-3 flex items-center gap-2">
                <span>🏦</span> Bank Transfer
              </h3>
              <ul class="space-y-2 text-sm text-gray-700">
                <li><strong>Bank:</strong> Co-Operative Bank</li>
                <li><strong>Account Name:</strong> Futon Pacifika</li>
                <li><strong>Account Number:</strong> 69285785</li>
                <li><strong>Sort Code:</strong> 08-92-99</li>
                <li><strong>IBAN:</strong> GB90CPBK 08929969285785</li>
                <li><strong>BIC Code:</strong> CPBKGB22</li>
                <li><strong>Reference:</strong> Order ${order.invoiceNumber}</li>
                <li><strong>Amount:</strong> £${order.total.toFixed(2)}</li>
              </ul>
            </div>
            
            <div class="bg-blue-50 border-l-4 border-blue-600 p-6 rounded">
              <h3 class="text-lg font-semibold text-blue-900 mb-3 flex items-center gap-2">
                <span>✉️</span> Cheque Payment
              </h3>
              <div class="text-sm text-gray-700 space-y-2">
                <p><strong>Make payable to:</strong> Futon Pacifika</p>
                <p><strong>Amount:</strong> £${order.total.toFixed(2)}</p>
                <p><strong>Mail to:</strong></p>
                <address class="not-italic ml-4">
                  Futon Pacifika<br>
                  18b Bess Park Road<br>
                  Wadebridge, Cornwall PL27 6HB
                </address>
                <p><strong>Write on back of cheque:</strong> Order ${order.invoiceNumber}</p>
              </div>
            </div>
          </div>
          
          <div class="bg-blue-50 border border-blue-200 rounded p-4 mt-6">
            <p class="text-sm text-blue-800">
              📧 We will automatically confirm your order and process shipping as soon as we receive your payment (usually within 1-2 business days).
            </p>
          </div>
        </div>
      `;
    } else {
      // Credit card payment - show success message
      const paymentMethod =
        order.paymentDetails && order.paymentDetails.method
          ? order.paymentDetails.method
          : "card";
      paymentInstructionsHTML = `
        <div class="border-t border-gray-200 pt-6 mt-6">
          <div class="bg-green-50 border-l-4 border-green-600 p-6 rounded">
            <h2 class="text-xl font-semibold text-green-900 mb-2">Payment Confirmed</h2>
            <p class="text-gray-700">Your payment has been processed successfully${paymentMethod !== "DeferredPayment" ? " via " + paymentMethod : ""}.</p>
            <p class="text-gray-700 mt-2">✓ Your order will be prepared and shipped shortly.</p>
            <p class="text-gray-700">✓ You'll receive a shipping confirmation email once your order is on its way.</p>
            <p class="text-gray-700">✓ A receipt has been sent to ${order.email}.</p>
          </div>
        </div>
      `;
    }

    // Render the complete order confirmation
    const confirmationHTML = `
      <div class="bg-white rounded-lg shadow-lg p-8">
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h1 class="text-3xl font-bold text-gray-900 mb-2">Thank you for your order!</h1>
          <p class="text-gray-600">
            Order Number: <strong class="text-gray-900">${order.invoiceNumber || order.token || "Pending"}</strong>
          </p>
          ${
            order.email
              ? `
            <p class="text-gray-600">
              Email: <strong class="text-gray-900">${order.email}</strong>
            </p>
          `
              : ""
          }
        </div>

        <!-- Order Items -->
        <div class="border-t border-gray-200 pt-6 mb-6">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Order Items</h2>
          <div class="space-y-2">
            ${itemsHTML}
          </div>
        </div>

        <!-- Order Summary -->
        <div class="border-t-2 border-gray-300 pt-4 space-y-2">
          <div class="flex justify-between text-gray-700">
            <span>Subtotal:</span>
            <span>£${(order.subtotal || 0).toFixed(2)}</span>
          </div>
          ${
            order.shippingDetails && order.shippingDetails.cost > 0
              ? `
            <div class="flex justify-between text-gray-700">
              <span>Shipping (${order.shippingDetails.method || "Standard"}):</span>
              <span>£${order.shippingDetails.cost.toFixed(2)}</span>
            </div>
          `
              : ""
          }
          <div class="flex justify-between text-xl font-bold text-gray-900 pt-3 mt-3 border-t-2 border-gray-300">
            <span>Total:</span>
            <span>£${(order.total || 0).toFixed(2)}</span>
          </div>
        </div>

        ${paymentInstructionsHTML}

        <!-- Shipping Address -->
        ${
          order.shippingAddress
            ? `
          <div class="border-t border-gray-200 pt-6 mt-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">Shipping Address</h2>
            <address class="not-italic text-gray-700">
              ${order.shippingAddress.name}<br>
              ${order.shippingAddress.address1}<br>
              ${order.shippingAddress.address2 ? order.shippingAddress.address2 + "<br>" : ""}
              ${order.shippingAddress.city}, ${order.shippingAddress.province || ""} ${order.shippingAddress.postalCode}<br>
              ${order.shippingAddress.country}
            </address>
          </div>
        `
            : ""
        }
      </div>

      <div class="mt-8 pt-6 border-t border-gray-200 text-center">
        <p class="text-gray-600 text-sm mb-4">
          Questions? Contact us at orders@futonpacifika.co.uk
        </p>
        <div class="flex justify-center gap-4">
          <a href="/" class="inline-block bg-blue-600 text-white px-6 py-3 rounded font-medium hover:bg-blue-700 transition">
            Continue Shopping
          </a>
          <button
            id="print-button"
            class="inline-block bg-gray-600 text-white px-6 py-3 rounded font-medium hover:bg-gray-700 transition"
          >
            Print Order Confirmation
          </button>
        </div>
      </div>
    `;

    document.getElementById("order-confirmation-container").innerHTML =
      confirmationHTML;

    // Add print button listener
    const printButton = document.getElementById("print-button");
    if (printButton) {
      printButton.addEventListener("click", () => window.print());
    }

    // Clear localStorage after displaying (prevents showing old orders on return visits)
    localStorage.removeItem("snipcartLastOrder");
  }
</script>
