---
import { Icon } from 'astro-icon/components';
---
<footer class="prose  max-w-none py-8 px-6 lg:px-32 md:px-16 border-t-2 border-gray-100  text-red-600 font-karma uppercase w-full">

<div class="grid grid-cols-1 lg:grid-cols-3 md:grid-cols-3 lg:gap-0 md:gap-0 items-center gap-5 w-full">

<div class="lg:text-left md:text-left text-center text-red-600 font-karma">
<a class="inline-block w-auto text-red-600 font-karma" href="/">© 2025  <span class="text-red-600"> Futon Pacifika </span></a>
</div>

<div class=" text-center">
<a class="inline-block px-1  w-auto text-red-600 font-karma"  href={'/payment'}>Payment</a>
<a class="inline-block px-1 w-auto text-red-600 font-karma"  href={'/delivery'}>Delivery</a>
<a class="inline-block px-1 w-auto text-red-600 font-karma"  href={'/terms'}>Terms</a>
</div>

<div class="lg:text-end md:text-end space-x-2 text-center">
<a class="inline-block w-auto text-red-500" w-auto href='https://www.facebook.com/futonpacifika'>
<Icon name="mdi:facebook"  size={24} />
</a>
<a class="inline-block w-auto text-red-500" href='https://x.com/futonpacifika'> 
<Icon name="mdi:twitter" size={24} />
</a>
</div>

</div>

</footer>

