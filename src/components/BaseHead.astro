---
import { siteConfig } from "@/utils/site.config";
import Fonts from "@/layouts/Fonts.astro";
import "@/styles/global.scss";

export interface Props {
	title: string
	description?: string
	ogImage?: string | undefined
}

const { title, description = siteConfig.description, ogImage } = Astro.props
const canonicalURL = new URL(Astro.request.url, Astro.site);
const socialImageURL = new URL(ogImage ? ogImage : "/logo.png", Astro.url).href;

const titleSeparator = "•";

const siteTitle = `${title} ${titleSeparator} ${siteConfig.title}`;


---

<meta charset="utf-8" />
<meta name='viewport' content='width=device-width,initial-scale=1' />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="apple-touch-icon" href="/favicon.png"  />
<meta name="generator" content={Astro.generator} />
<link href="/manifest.webmanifest" rel="manifest" />

<link href={canonicalURL} rel="canonical" />

<title>{siteTitle}</title>

<meta name="title" content={siteTitle}  />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author} />

<meta content="" name="theme-color" />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={siteConfig.title} />
<meta property="og:locale" content={siteConfig.ogLocale} />
<meta property="og:image" content={socialImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta property="twitter:card" content="summary_large_image"/>
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageURL} />

<link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.3.0/default/snipcart.css" />

<Fonts/>

<script is:inline src="https://cdn.jsdelivr.net/npm/flowbite@2.5.1/dist/flowbite.min.js"></script>
