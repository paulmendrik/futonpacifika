---
import BaseHead from "@/components/BaseHead.astro";
import { siteConfig } from "@/utils/site.config";
import type { SiteMeta } from "@/utils/types";
import Header from "@/components/Header.astro";
import Footer from '@/components/Footer.astro';

interface Props {
	meta: SiteMeta;
}

const {
	meta: { description = siteConfig.description, ogImage, title },
} = Astro.props;

---

<!doctype html>
<html class=" scroll-smooth" lang={siteConfig.lang} >
<head>

<BaseHead description={description} ogImage={ogImage} title={title} />

</head>
<body  class="flex flex-col items-center h-[100svh]" transition:animate="slide" >
<div class="w-full px-4 max-w-7xl flex-grow">
<Header />
<div class="pb-10">
<div class="main lg:px-0 md:px-4 sm:px-4  prose lg:prose-p:text-lg prose-p:text-base max-w-none">
<slot />
</div>
</div>
</div>
<Footer/>
</body>
</html>