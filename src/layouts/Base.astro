---

import BaseHead from '@/components/BaseHead.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import Head from '../components/Head.astro';
import Footer from '../components/Footer.astro';

const { title, description, image } = Astro.props

---

<html lang="en" class="h-full motion-safe:scroll-smooth" >
<head> 
<BaseHead description={description} ogImage={image} title={title} />
</head>
<body  class="flex flex-col items-center h-screen" transition:animate="slide" >
<Head />
<slot/>
<div class="w-full flex-grow px-6 lg:px-32 md:px-16">
<div class="w-full lg:mb-8 mb-6 border-b-2 border-slate-100">
</div>
<slot/>
<br/>
<CookieConsent/>
</div>
<Footer/>
</body>
</html>
